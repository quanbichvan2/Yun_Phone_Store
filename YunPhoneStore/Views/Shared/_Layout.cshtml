<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuanBichVanPS28709_ASM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuanBichVanPS28709_ASM.styles.css" asp-append-version="true" />
    <link href="~/css/main.css rel=" stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

</head>

<body>
    <header>
        <div class="custom-dark-bg" style="background-color: #2f3131">
            <div class="container py-2">
                <div class="row align-items-center">
                    <div class="col-md-6 ">
                        <!-- Adjust the column width as per your requirement -->
                        <div class="input-group" style="padding: 0.5rem;justify-content: flex-end;">
                            <input class="form-control rounded-pill border-0 bg-white" id="search" type="search"
                                placeholder="Search For..." style="max-width: 20rem; margin-right: 0.5rem;" />
                            <button type="button"
                                class="btn rounded-pill bg-light text-secondary border-0 shadow-sm input-group-text">
                                <span class="visually-hidden">Search</span>
                                <i class="bi bi-search" style="color: black;"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <!-- Adjust the column width as per your requirement -->
                        <div class="d-flex justify-content-end">
                            <a href="#"
                                class="btn rounded-pill bg-light text-secondary border-0 shadow-sm hover-text-dark me-2">
                                <span class="visually-hidden">Notifications</span>
                                <i class="bi bi-bell-fill" style="color: black;"></i>
                            </a>
                            <a href="#"
                                class="btn rounded-pill bg-light text-secondary border-0 shadow-sm hover-text-dark me-2">
                                <span class="visually-hidden">Favorites</span>
                                <i class="bi bi-box2-heart" style="color: black;"></i>
                            </a>
                            <a href="#"
                                class="btn rounded-pill bg-light text-secondary border-0 shadow-sm hover-text-dark me-2">
                                <span class="visually-hidden">Cart</span>
                                <i class="bi bi-cart3" style="color: black;"></i>
                            </a>
                            <a class="btn rounded-pill bg-light text-secondary border-0 shadow-sm hover-text-dark me-2"
                                href="#!login" ng-click="toggleProfile()">Sign In</a>
                            <a class="btn rounded-pill bg-light text-secondary border-0 shadow-sm hover-text-dark me-2"
                                href="#!register" ng-click="toggleProfile()">Sign Up</a>
                            <a href="#" class="profile hover-text-dark me-2">
                                <span class="visually-hidden">Profile</span>
                                <img alt="Man"
                                    src="https://images.unsplash.com/photo-1600486913747-55e5470d6f40?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1770&q=80"
                                    class="img-fluid rounded-circle"
                                    style="width: 37px; height: 37px; object-fit: cover; display: none;" />
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <nav class="row">
        <img class="pull-right"
            src="https://img.tgdd.vn/imgt/f_webp,fit_outside,quality_100/https://cdn.tgdd.vn/2024/03/banner/1920x450--1--1920x450.jpg"
            alt="Banner Big Campaign">
        <div class="taskbar" id="custom-navbar">
            <nav class="navbar navbar-expand-lg navbar-light bg-light">
                <div class="collapse navbar-collapse" id="navbarNavDropdown" style="justify-content: center;">
                    <ul class="navbar-nav">
                        <li class="nav-item active">
                            <a class="nav-link" asp-action="Index" asp-controller="Home"> <i class="bi bi-house-door-fill"> </i>Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-action="Index" asp-controller="Product"> <i class="bi bi-flower3"> </i>Laptop</a>
                        </li>
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                    Phone
                                </a>
                                <ul class="dropdown-menu">
                                    <!-- đang bug đoạn này -->
                                    <li><a class="dropdown-item" asp-action="Details" asp-controller="Product"> Apple</a></li>
                                    <div class="dropdown-divider"></div>
                                    <li><button class="dropdown-item" type="button"> Samsung</button>
                                    </li>
                                    <li><button class="dropdown-item" type="button" > XiaoMi </button></li>
                                    <li><button class="dropdown-item" type="button" > Oppo </button>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                        <li class="nav-item">
                            <a class="nav-link" href="#!list-view"> <i class="bi bi-fire"> </i> On Sales</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#!ContactUs"> <i class="bi bi-envelope-fill"> </i> Contact Us</a>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
    </nav>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* <footer class="border-top footer text-muted">
    <div class="container">
    &copy; 2024 - QuanBichVanPS28709_ASM - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
    </footer> *@
    <footer class="text-center text-lg-start text-muted mt-3" style="background-color:#c9dfec;">
        <div class="footer-top">
            <div class="container pt-4 pb-4">
                <div class="row gy-5">
                    <div class="col-lg-4">
                        <a href="" style="color: black; font-size: 2rem;">YunEddy</a>
                        <p>
                            Lorem ipsum dolor sit amet consectetur adipisicing elit. Reprehenderit architecto unde
                            magnam.
                        </p>
                        <div class="social-links">
                            <a href="#" target=""><i class="ri-facebook-circle-fill"></i></a>
                            <a href="#" target=""><i class="ri-instagram-fill"></i></a>
                            <a href="#" target=""><i class="ri-links-fill"></i></a>
                            <a href="#" target=""><i class="ri-youtube-fill"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-3 ms-auto">
                        <h6 class="text-black mb-4">Find Us At</h6>
                        <p class="mb-1">Phone: (+84) 929 435 927</p>
                        <p class="mb-1">Email: vanqbps28709@fpt.edu.vn</p>
                        <p class="mb-0">
                            Address: 45 HIGHWAY, CA, USA
                        </p>
                    </div>
                    <div class="col-lg-3">
                        <h6 class="text-black mb-4">Time Open</h6>
                        <p class="mb-1">Monday to Friday: 10am - 9pm</p>
                        <p>Saturday to Sunday: 9am - 9pm</p>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
